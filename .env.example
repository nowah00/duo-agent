# 파일 변경 감지 후 에이전트 실행까지 대기 시간 (ms)
WATCH_DEBOUNCE_MS=3000

# 최대 협업 라운드 수 (초과 시 사용자 확인 대기)
AGENT_MAX_ROUNDS=8

# 먼저 실행할 에이전트 ('claude' 또는 'codex')
FIRST_AGENT=codex

# Anthropic API 키 (채팅 기반 kick에 필요)
ANTHROPIC_API_KEY=your_api_key_here

# Claude Code CLI 명령어 (기본값: claude)
CLAUDE_CMD=claude

# Codex CLI 명령어 (기본값: codex)
CODEX_CMD=codex

# Claude에게 허용할 툴 목록 (기본값: Read,Edit,Bash(npm run build),Bash(npm test))
CLAUDE_ALLOWED_TOOLS=Read,Edit,Bash(npm run build),Bash(npm test)

# 에이전트 실패 시 자동 재시도 횟수 (기본값: 1)
AGENT_MAX_RETRIES=1

# 에이전트 최대 실행 시간 (ms, 기본값: 600000 = 10분)
AGENT_TIMEOUT_MS=600000
